XAI_API_KEY=
# OPENAI_API_KEY=
# AI_API_URL=https://api.x.ai/v1/chat/completions
# AI_MODEL=grok-3-mini
# AI_RATE_LIMIT_PER_HOUR=30
# Chế độ: auto (có key = AI API, không có = rule-based), rule, ai — cấu hình thêm trong Admin > Cài đặt AI

# ─── Bảo mật (Defense in Depth) ───
# Cloudflare Turnstile — https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
FORCE_HSTS=true
CORS_ORIGINS=https://ai-pro-store.onrender.com
JWT_EXPIRE_HOURS=24
LOCKOUT_ATTEMPTS=5
LOCKOUT_MINUTES=15
PASSWORD_MIN_LENGTH=8
RATE_GLOBAL_PER_MIN=120
RATE_AUTH_PER_MIN=10
MAX_SESSIONS_PER_USER=3
STEP_UP_ALL_PRO=true
SECURITY_ALERT_WEBHOOK=
# Discord/Slack webhook URL để nhận cảnh báo tấn công

# Google Drive — sao lưu ảnh MXH (ưu tiên OAuth admin, fallback Service Account)
# Tạo OAuth Client: Google Cloud Console > APIs & Services > Credentials > Web application
# Redirect URI: https://ai-pro-store.onrender.com/api/social/drive/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://ai-pro-store.onrender.com/api/social/drive/callback
# Tuỳ chọn — thư mục cố định (OAuth không bắt buộc; không có thì lưu vào Drive gốc)
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=